# ============================================================
# WebNesti Environment Variables
# ============================================================

# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL=file:./data/webnesti.db

# --- Security (REQUIRED in production, >= 32 chars each) ---
# JWT_SECRET signs session tokens. Generate: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-in-production
# ENCRYPTION_KEY encrypts BYOK provider keys at rest (AES-256-GCM). >= 32 chars.
ENCRYPTION_KEY=dev-encryption-key-change-me-32b!!

# --- Pricing ---
# Default markup percent applied on top of provider cost (e.g. 10 = +10%)
DEFAULT_MARKUP_PERCENT=10

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=https://webnesti.ai,http://localhost:3000

# --- DB tuning (optional) ---
# Flush interval for sql.js auto-save in ms (default 2000)
DB_FLUSH_MS=2000

# ============================================================
# Provider API Keys (leave empty to disable a provider)
# ============================================================

# --- First-party providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
META_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# --- OpenAI-compatible providers ---
GROQ_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
MOONSHOT_API_KEY=
ZAI_API_KEY=
MINIMAX_API_KEY=
QWEN_API_KEY=

# ============================================================
# Midtrans Payment Gateway (optional, Indonesia)
# ============================================================
MIDTRANS_SERVER_KEY=
# Set to "true" for production Midtrans, "false"/empty for sandbox
MIDTRANS_IS_PRODUCTION=false
