# WebNesti Environment Variables
PORT=3000
HOST=0.0.0.0
DATABASE_URL=file:./data/webnesti.db
JWT_SECRET=change-this-to-a-random-secret-in-production
DEFAULT_MARKUP_PERCENT=10

# Provider API Keys (leave empty to disable provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
META_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=

# Midtrans Payment Gateway (optional)
MIDTRANS_SERVER_KEY=
