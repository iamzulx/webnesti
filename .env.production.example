# Production environment template
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# REQUIRED in production (min 32 chars)
JWT_SECRET=
ENCRYPTION_KEY=

# Comma-separated origins
CORS_ORIGINS=https://webnesti.ai,http://localhost:3000

# Keep data persistent across restarts
DATABASE_URL=./data/webnesti.db

# Provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
META_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
MOONSHOT_API_KEY=
ZAI_API_KEY=
MINIMAX_API_KEY=
DASHSCOPE_API_KEY=

# Billing (Indonesia)
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false

# Optional
DEFAULT_MARKUP_PERCENT=10
DEFAULT_MAX_OUTPUT_TOKENS=4096
SEED_ON_START=true
